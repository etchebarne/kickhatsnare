{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "plugins": ["react", "unicorn", "typescript", "oxc"],
  "env": {
    "browser": true,
    "node": true
  },
  "ignorePatterns": ["out/**", "dist/**", "node_modules/**"]
}
